# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
# ⚠️ Keep this as "disabled=1" — do NOT change it to a number (e.g. 999999).
# "disabled=1" turns OFF the Symfony PHPUnit Bridge deprecation handler, so PHPUnit
# handles deprecations natively, where phpunit.dist.xml gates them like notices/warnings:
#   failOnDeprecation="true" + <source ignoreIndirectDeprecations="true">
# => deprecations triggered by OUR code (src/) fail the suite, like failOnNotice;
#    deprecations from vendor/ (indirect) are ignored.
# A numeric value re-enables the bridge, which tolerates everything and SILENTLY
# disables this gate (failOnDeprecation becomes a no-op).
SYMFONY_DEPRECATIONS_HELPER=disabled=1

###> symfony/framework-bundle ###
SYMFONY_TRUSTED_HOSTS=(^|\.)turbolab\.it$
###< symfony/framework-bundle ###
