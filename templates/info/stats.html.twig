{% extends 'base.html.twig' %}

{% block stylesheets %}

    {{ parent() }}
    {{ inline_css('build/stats.css') }}

{% endblock %}

{% block bodyMainContent %}

    <section class="post-layout-1-area">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="about-author-content">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
                                <li class="breadcrumb-item">Statistiche</li>
                            </ol>
                        </nav>
                    </div>
                </div>

                <article class="col-lg-12">

                    <div class="post-layout-top-content post-layout-top-content-3 tli-article-main-content">

                        <div class="post-content">
                            <h1 class="title">{{ metaTitle }}</h1>
                        </div>

                        <div class="post-text mt-30">

                            <p>
                                Dati forniti da <em>Google Analytics</em>. Per ogni grafico mostriamo, in grigio,
                                il confronto con lo stesso giorno della settimana dell'anno precedente.<br>
                                Passa il mouse sul grafico per vedere il dettaglio giorno per giorno.
                            </p>


                            {% if not StatsConfigured %}

                                <div class="tli-stats-card">
                                    <div class="tli-stats-empty">
                                        <i class="fa-solid fa-triangle-exclamation fa-2x" style="color: #e5a50a;"></i>
                                        <h3 class="mt-20">Statistiche non ancora configurate</h3>
                                        {% if CurrentUser.isAdmin ?? false %}
                                            <p>
                                                Mancano la property ID di Google Analytics 4 e/o il file delle credenziali
                                                del service account.<br>
                                                Imposta la variabile di ambiente <code>APP_GOOGLE_ANALYTICS_PROPERTY_ID</code>
                                                e copia la chiave JSON del service account in
                                                <code>var/google-analytics-credentials.json</code>.
                                            </p>
                                        {% endif %}
                                    </div>
                                </div>

                            {% elseif StatsError %}

                                <div class="tli-stats-card">
                                    <div class="tli-stats-empty">
                                        <i class="fa-solid fa-circle-exclamation fa-2x" style="color: #e01b24;"></i>
                                        <h3 class="mt-20">Errore nel recupero dei dati</h3>
                                        <p>{{ StatsError }}</p>
                                    </div>
                                </div>

                            {% else %}

                                {# === Headline totals (GA-style) === #}
                                {% set pvCurInit  = Stats.totals.pageViews.current %}
                                {% set auCurInit  = Stats.totals.activeUsers.current %}
                                {% set ruCurInit  = Stats.totals.registeredUsers.current %}
                                {% set apCurInit  = Stats.totals.articlesPublished.current %}
                                {% set daysInit   = Stats.range.days %}
                                {% set pvAvgInit  = daysInit > 0 ? (pvCurInit / daysInit)|round : 0 %}
                                {% set auAvgInit  = daysInit > 0 ? (auCurInit / daysInit)|round : 0 %}
                                <div class="tli-stats-headline" id="tli-stats-headline">
                                    <div class="tli-stats-headline-totals">
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Visualizzazioni</span>
                                            <span class="tli-stats-headline-value"
                                                  data-tli-headline="pageViews">{{ pvCurInit|number_format(0, ',', '.') }}</span>
                                        </div>
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Visitatori univoci</span>
                                            <span class="tli-stats-headline-value"
                                                  data-tli-headline="activeUsers">{{ auCurInit|number_format(0, ',', '.') }}</span>
                                        </div>
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Visualizzazioni/giorno</span>
                                            <span class="tli-stats-headline-value"
                                                  data-tli-headline="pageViewsAvg">{{ pvAvgInit|number_format(0, ',', '.') }}</span>
                                        </div>
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Visitatori univoci/giorno</span>
                                            <span class="tli-stats-headline-value"
                                                  data-tli-headline="activeUsersAvg">{{ auAvgInit|number_format(0, ',', '.') }}</span>
                                        </div>
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Nuovi utenti registrati</span>
                                            <span class="tli-stats-headline-value"
                                                  data-tli-headline="registeredUsers">{{ ruCurInit|number_format(0, ',', '.') }}</span>
                                        </div>
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Articoli pubblicati</span>
                                            <span class="tli-stats-headline-value"
                                                  data-tli-headline="articlesPublished">{{ apCurInit|number_format(0, ',', '.') }}</span>
                                        </div>
                                    </div>
                                    <div class="tli-stats-headline-range">
                                        <span class="tli-stats-headline-range-tag" data-tli-headline-range>
                                            {{ Stats.range.start|date('d/m/Y') }} – {{ Stats.range.end|date('d/m/Y') }}
                                        </span>
                                    </div>
                                </div>

                                {# === Range selector === #}
                                <div class="tli-stats-range-selector" id="tli-stats-range-selector"
                                     data-ajax-url="{{ path('app_stats_ajax') }}">
                                    <span class="tli-stats-range-label">Periodo:</span>
                                    {% for days in StatsAllowedDays %}
                                        <button type="button"
                                                class="tli-stats-range-pill {{ days == StatsDefaultDays ? 'tli-active' : '' }}"
                                                data-days="{{ days }}">
                                            {{ days }} giorni
                                        </button>
                                    {% endfor %}
                                    <span class="tli-stats-range-spinner">
                                        <i class="fa-solid fa-circle-notch fa-spin"></i>
                                    </span>
                                </div>

                                {# === Pageviews === #}
                                <div class="tli-stats-card" id="tli-stats-card-pageviews">

                                    <h3><i class="fa-solid fa-eye" style="color: #1091ff;"></i> Visualizzazioni di pagina</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta></div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Periodo attuale</span>
                                            <span class="tli-stats-total-value" data-tli-stats-current>—</span>
                                        </div>
                                        <div class="tli-stats-total tli-last-year">
                                            <span class="tli-stats-total-label">Anno scorso</span>
                                            <span class="tli-stats-total-value" data-tli-stats-lastyear>—</span>
                                        </div>
                                        <div class="tli-stats-total" data-tli-stats-delta-wrap>
                                            <span class="tli-stats-total-label">Variazione</span>
                                            <span class="tli-stats-total-value tli-stats-trend" data-tli-stats-delta>—</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-pageviews"></canvas>
                                    </div>
                                </div>

                                {# === Active users === #}
                                <div class="tli-stats-card" id="tli-stats-card-activeusers">

                                    <h3><i class="fa-solid fa-users" style="color: #26a269;"></i> Visitatori univoci</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta></div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Periodo attuale</span>
                                            <span class="tli-stats-total-value" data-tli-stats-current>—</span>
                                        </div>
                                        <div class="tli-stats-total tli-last-year">
                                            <span class="tli-stats-total-label">Anno scorso</span>
                                            <span class="tli-stats-total-value" data-tli-stats-lastyear>—</span>
                                        </div>
                                        <div class="tli-stats-total" data-tli-stats-delta-wrap>
                                            <span class="tli-stats-total-label">Variazione</span>
                                            <span class="tli-stats-total-value tli-stats-trend" data-tli-stats-delta>—</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-activeusers"></canvas>
                                    </div>
                                </div>

                                {# === Top pages === #}
                                {% if CurrentUser and CurrentUser.isEditor %}
                                <div class="tli-stats-card" id="tli-stats-card-toppages">

                                    <h3><i class="fa-solid fa-trophy" style="color: #e5a50a;"></i> Pagine più viste</h3>
                                    <div class="tli-stats-card-meta" data-tli-toppages-meta>
                                        Dal {{ Stats.range.start|date('d/m/Y') }}
                                        al {{ Stats.range.end|date('d/m/Y') }}
                                    </div>
                                    <div class="tli-stats-staff-only">
                                        <i class="fa-solid fa-lock"></i> Questa sezione è visibile solo ai membri dello staff
                                    </div>

                                    {% if Stats.topPages is empty %}
                                        <div class="tli-stats-toppages-empty" data-tli-toppages-empty>
                                            Nessun dato disponibile per il periodo selezionato.
                                        </div>
                                    {% endif %}

                                    {% set splitAt = (Stats.topPages|length / 2)|round(0, 'ceil') %}
                                    <div class="tli-stats-toppages-grid"
                                         data-tli-toppages-grid
                                         {% if Stats.topPages is empty %}style="display:none"{% endif %}>

                                        {% for col in [0, 1] %}
                                            {% set fromIdx = col * splitAt %}
                                            {% set slice   = Stats.topPages|slice(fromIdx, splitAt) %}
                                            <table class="tli-stats-toppages-table">
                                                <thead>
                                                    <tr>
                                                        <th class="tli-stats-toppages-rank">#</th>
                                                        <th class="tli-stats-toppages-title">Pagina</th>
                                                        <th class="tli-stats-toppages-views">Visualizzazioni</th>
                                                    </tr>
                                                </thead>
                                                <tbody data-tli-toppages-body="{{ col }}">
                                                    {% for page in slice %}
                                                        <tr>
                                                            <td class="tli-stats-toppages-rank">{{ fromIdx + loop.index }}</td>
                                                            <td>
                                                                <span class="tli-stats-toppages-page-title">
                                                                    <a href="{{ page.path }}" target="_blank" rel="noopener">
                                                                        {%- if page.iconClass -%}
                                                                            <i class="fa-solid {{ page.iconClass }}" style="color: {{ page.iconColor }};"></i>
                                                                        {% endif %}
                                                                        {{- page.displayTitle -}}
                                                                    </a>
                                                                </span>
                                                            </td>
                                                            <td class="tli-stats-toppages-views">{{ page.views|number_format(0, ',', '.') }}</td>
                                                        </tr>
                                                    {% endfor %}
                                                </tbody>
                                            </table>
                                        {% endfor %}

                                    </div>
                                </div>
                                {% endif %}

                                {# === Top tags === #}
                                {% if CurrentUser and CurrentUser.isEditor %}
                                <div class="tli-stats-card" id="tli-stats-card-toptags">

                                    <h3><i class="fa-solid fa-tags" style="color: #e5a50a;"></i> Tag più visti</h3>
                                    <div class="tli-stats-card-meta" data-tli-toptags-meta>
                                        Dal {{ Stats.range.start|date('d/m/Y') }}
                                        al {{ Stats.range.end|date('d/m/Y') }}
                                    </div>
                                    <div class="tli-stats-staff-only">
                                        <i class="fa-solid fa-lock"></i> Questa sezione è visibile solo ai membri dello staff
                                    </div>

                                    {% if Stats.topTags is empty %}
                                        <div class="tli-stats-toppages-empty" data-tli-toptags-empty>
                                            Nessun dato disponibile per il periodo selezionato.
                                        </div>
                                    {% endif %}

                                    {% set splitAtT = (Stats.topTags|length / 2)|round(0, 'ceil') %}
                                    <div class="tli-stats-toppages-grid"
                                         data-tli-toptags-grid
                                         {% if Stats.topTags is empty %}style="display:none"{% endif %}>

                                        {% for col in [0, 1] %}
                                            {% set fromIdx = col * splitAtT %}
                                            {% set slice   = Stats.topTags|slice(fromIdx, splitAtT) %}
                                            <table class="tli-stats-toppages-table">
                                                <thead>
                                                    <tr>
                                                        <th class="tli-stats-toppages-rank">#</th>
                                                        <th class="tli-stats-toppages-title">Tag</th>
                                                        <th class="tli-stats-toppages-views">Visualizzazioni</th>
                                                    </tr>
                                                </thead>
                                                <tbody data-tli-toptags-body="{{ col }}">
                                                    {% for tag in slice %}
                                                        {% set tagTitle = tag.title|trim is empty ? tag.path : tag.title %}
                                                        <tr>
                                                            <td class="tli-stats-toppages-rank">{{ fromIdx + loop.index }}</td>
                                                            <td>
                                                                <span class="tli-stats-toppages-page-title">
                                                                    <a href="{{ tag.path }}" target="_blank" rel="noopener">
                                                                        <i class="fa-solid fa-tag" style="color: #e5a50a;"></i> {{ tagTitle }}
                                                                    </a>
                                                                </span>
                                                            </td>
                                                            <td class="tli-stats-toppages-views">{{ tag.views|number_format(0, ',', '.') }}</td>
                                                        </tr>
                                                    {% endfor %}
                                                </tbody>
                                            </table>
                                        {% endfor %}

                                    </div>
                                </div>
                                {% endif %}

                                {# === Articles published === #}
                                <div class="tli-stats-card" id="tli-stats-card-articlespublished">

                                    <h3><i class="fa-solid fa-book-open" style="color: #7068b1;"></i> Articoli pubblicati</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta></div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Periodo attuale</span>
                                            <span class="tli-stats-total-value" data-tli-stats-current>—</span>
                                        </div>
                                        <div class="tli-stats-total tli-last-year">
                                            <span class="tli-stats-total-label">Anno scorso</span>
                                            <span class="tli-stats-total-value" data-tli-stats-lastyear>—</span>
                                        </div>
                                        <div class="tli-stats-total" data-tli-stats-delta-wrap>
                                            <span class="tli-stats-total-label">Variazione</span>
                                            <span class="tli-stats-total-value tli-stats-trend" data-tli-stats-delta>—</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-articlespublished"></canvas>
                                    </div>
                                </div>

                                {# === Forum activity === #}
                                <div class="tli-stats-card" id="tli-stats-card-forum">

                                    <h3><i class="fa-solid fa-comments" style="color: #9141ac;"></i> Nuovi post pubblicati sul forum</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta></div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Periodo attuale</span>
                                            <span class="tli-stats-total-value" data-tli-stats-current>—</span>
                                        </div>
                                        <div class="tli-stats-total tli-last-year">
                                            <span class="tli-stats-total-label">Anno scorso</span>
                                            <span class="tli-stats-total-value" data-tli-stats-lastyear>—</span>
                                        </div>
                                        <div class="tli-stats-total" data-tli-stats-delta-wrap>
                                            <span class="tli-stats-total-label">Variazione</span>
                                            <span class="tli-stats-total-value tli-stats-trend" data-tli-stats-delta>—</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-forumposts"></canvas>
                                    </div>

                                    <h4 style="font-size: 16px; color: #515a60; margin: 26px 0 8px;">
                                        <i class="fa-solid fa-trophy" style="color: #e5a50a;"></i>
                                        Utenti più attivi
                                    </h4>

                                    {% if Stats.topPosters is empty %}
                                        <div class="tli-stats-toppages-empty" data-tli-topposters-empty>
                                            Nessun dato disponibile per il periodo selezionato.
                                        </div>
                                    {% endif %}

                                    {% set splitAtP = (Stats.topPosters|length / 2)|round(0, 'ceil') %}
                                    <div class="tli-stats-toppages-grid"
                                         data-tli-topposters-grid
                                         {% if Stats.topPosters is empty %}style="display:none"{% endif %}>

                                        {% for col in [0, 1] %}
                                            {% set fromIdx = col * splitAtP %}
                                            {% set slice   = Stats.topPosters|slice(fromIdx, splitAtP) %}
                                            <table class="tli-stats-toppages-table">
                                                <thead>
                                                    <tr>
                                                        <th class="tli-stats-toppages-rank">#</th>
                                                        <th class="tli-stats-toppages-title">Utente</th>
                                                        <th class="tli-stats-toppages-views">Post</th>
                                                    </tr>
                                                </thead>
                                                <tbody data-tli-topposters-body="{{ col }}">
                                                    {% for poster in slice %}
                                                        <tr>
                                                            <td class="tli-stats-toppages-rank">{{ fromIdx + loop.index }}</td>
                                                            <td>
                                                                <span class="tli-stats-toppages-page-title">
                                                                    <a href="/forum/memberlist.php?mode=viewprofile&u={{ poster.userId }}"
                                                                       target="_blank" rel="noopener"
                                                                       {% if poster.colour|trim is not empty %}style="color: #{{ poster.colour }};"{% endif %}>
                                                                        <i class="fa-solid fa-user"></i> {{ poster.username }}
                                                                    </a>
                                                                </span>
                                                            </td>
                                                            <td class="tli-stats-toppages-views">{{ poster.posts|number_format(0, ',', '.') }}</td>
                                                        </tr>
                                                    {% endfor %}
                                                </tbody>
                                            </table>
                                        {% endfor %}

                                    </div>
                                </div>

                                {# === Registered users === #}
                                <div class="tli-stats-card" id="tli-stats-card-registeredusers">

                                    <h3><i class="fa-solid fa-user-check" style="color: #1c9099;"></i> Numero totale di utenti registrati e attivati</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta>
                                        Dal {{ Stats.range.start|date('d/m/Y') }}
                                        al {{ Stats.range.end|date('d/m/Y') }}
                                    </div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Totale al termine del periodo</span>
                                            <span class="tli-stats-total-value"
                                                  data-tli-stats-current>{{ Stats.totals.registeredUsers.totalAtEnd|number_format(0, ',', '.') }}</span>
                                        </div>
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Nuovi nel periodo</span>
                                            <span class="tli-stats-total-value"
                                                  data-tli-stats-new-in-period>{{ Stats.totals.registeredUsers.current|number_format(0, ',', '.') }}</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-registeredusers"></canvas>
                                    </div>

                                    <div class="tli-stats-legend-hint">

                                    </div>
                                </div>

                                {# === Newsletter subscribers === #}
                                <div class="tli-stats-card" id="tli-stats-card-newsletter">

                                    <h3><i class="fa-solid fa-envelope-open-text" style="color: #e66100;"></i> Iscritti newsletter</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta>
                                        Dal {{ Stats.range.start|date('d/m/Y') }}
                                        al {{ Stats.range.end|date('d/m/Y') }}
                                    </div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Totale al termine del periodo</span>
                                            <span class="tli-stats-total-value"
                                                  data-tli-stats-current>{{ Stats.totals.newsletterSubscribers.totalAtEnd|number_format(0, ',', '.') }}</span>
                                        </div>
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Nuovi nel periodo</span>
                                            <span class="tli-stats-total-value"
                                                  data-tli-stats-new-in-period>{{ Stats.totals.newsletterSubscribers.current|number_format(0, ',', '.') }}</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-newsletter"></canvas>
                                    </div>

                                    <div class="tli-stats-legend-hint">
                                        Iscritti alla newsletter al termine di ogni giorno. <strong>Approssimato:</strong> phpBB
                                        non traccia opt-in/opt-out storici, gli utenti sono attribuiti alla data di
                                        registrazione in base all'opzione attualmente attiva.
                                    </div>
                                </div>

                                {# === Top referrers === #}
                                {% if CurrentUser and CurrentUser.isEditor %}
                                    <div class="tli-stats-card" id="tli-stats-card-topreferrers">

                                        <h3><i class="fa-solid fa-arrow-right-to-bracket" style="color: #9141ac;"></i> Top referrer</h3>
                                        <div class="tli-stats-card-meta" data-tli-topreferrers-meta>
                                            Dal {{ Stats.range.start|date('d/m/Y') }}
                                            al {{ Stats.range.end|date('d/m/Y') }}
                                        </div>
                                        <div class="tli-stats-staff-only">
                                            <i class="fa-solid fa-lock"></i> Questa sezione è visibile solo ai membri dello staff
                                        </div>

                                        {% if Stats.topReferrers is empty %}
                                            <div class="tli-stats-toppages-empty" data-tli-topreferrers-empty>
                                                Nessun dato disponibile per il periodo selezionato.
                                            </div>
                                        {% endif %}

                                        {% set splitAtR = (Stats.topReferrers|length / 2)|round(0, 'ceil') %}
                                        <div class="tli-stats-toppages-grid"
                                             data-tli-topreferrers-grid
                                             {% if Stats.topReferrers is empty %}style="display:none"{% endif %}>

                                            {% for col in [0, 1] %}
                                                {% set fromIdx = col * splitAtR %}
                                                {% set slice   = Stats.topReferrers|slice(fromIdx, splitAtR) %}
                                                <table class="tli-stats-toppages-table">
                                                    <thead>
                                                        <tr>
                                                            <th class="tli-stats-toppages-rank">#</th>
                                                            <th class="tli-stats-toppages-title">Referrer</th>
                                                            <th class="tli-stats-toppages-views">Visualizzazioni</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody data-tli-topreferrers-body="{{ col }}">
                                                        {% for ref in slice %}
                                                            <tr>
                                                                <td class="tli-stats-toppages-rank">{{ fromIdx + loop.index }}</td>
                                                                <td>
                                                                    {% if ref.url|trim is empty %}
                                                                        <span class="tli-stats-toppages-page-title tli-stats-direct">
                                                                            <i class="fa-solid fa-arrow-right" style="color: #9aa5ad;"></i>
                                                                            Traffico diretto
                                                                        </span>
                                                                    {% else %}
                                                                        <span class="tli-stats-toppages-page-title tli-stats-referrer-link">
                                                                            {{ ref.displayUrl }}
                                                                        </span>
                                                                    {% endif %}
                                                                </td>
                                                                <td class="tli-stats-toppages-views">{{ ref.views|number_format(0, ',', '.') }}</td>
                                                            </tr>
                                                        {% endfor %}
                                                    </tbody>
                                                </table>
                                            {% endfor %}

                                        </div>
                                    </div>
                                {% endif %}

                            {% endif %}

                        </div>
                    </div>

                </article>

            </div>
        </div>
    </section>

{% endblock %}

{% block javascripts %}

    {{ parent() }}

    {% if Stats %}
        <script type="application/json" id="tli-stats-initial-data">{{ Stats|json_encode|raw }}</script>
        {{ encore_entry_script_tags('stats') }}
    {% endif %}

{% endblock %}
