{% extends 'base.html.twig' %}

{% block stylesheets %}

    {{ parent() }}
    {{ inline_css('build/stats.css') }}

{% endblock %}

{% block bodyMainContent %}

    <section class="post-layout-1-area">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="about-author-content">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
                                <li class="breadcrumb-item">Statistiche</li>
                            </ol>
                        </nav>
                    </div>
                </div>

                <article class="col-lg-12">

                    <div class="post-layout-top-content post-layout-top-content-3 tli-article-main-content">

                        <div class="post-content">
                            <h1 class="title">{{ metaTitle }}</h1>
                        </div>

                        <div class="post-text mt-30">

                            <p>
                                Dati forniti da <em>Google Analytics</em>. Per ogni grafico mostriamo, in grigio,
                                il confronto con lo stesso giorno della settimana dell'anno precedente.<br>
                                Passa il mouse sul grafico per vedere il dettaglio giorno per giorno.
                            </p>


                            {% if not StatsConfigured %}

                                <div class="tli-stats-card">
                                    <div class="tli-stats-empty">
                                        <i class="fa-solid fa-triangle-exclamation fa-2x" style="color: #e5a50a;"></i>
                                        <h3 class="mt-20">Statistiche non ancora configurate</h3>
                                        {% if CurrentUser.isAdmin ?? false %}
                                            <p>
                                                Mancano la property ID di Google Analytics 4 e/o il file delle credenziali
                                                del service account.<br>
                                                Imposta la variabile di ambiente <code>APP_GOOGLE_ANALYTICS_PROPERTY_ID</code>
                                                e copia la chiave JSON del service account in
                                                <code>var/google-analytics-credentials.json</code>.
                                            </p>
                                        {% endif %}
                                    </div>
                                </div>

                            {% else %}

                                {# === Headline totals (GA-style) — values are populated by stats.js on AJAX load === #}
                                <div class="tli-stats-headline" id="tli-stats-headline">
                                    <div class="tli-stats-headline-totals">
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Visualizzazioni</span>
                                            <span class="tli-stats-headline-value" data-tli-headline="pageViews">—</span>
                                        </div>
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Visitatori univoci</span>
                                            <span class="tli-stats-headline-value" data-tli-headline="activeUsers">—</span>
                                        </div>
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Visualizzazioni/giorno</span>
                                            <span class="tli-stats-headline-value" data-tli-headline="pageViewsAvg">—</span>
                                        </div>
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Visitatori univoci/giorno</span>
                                            <span class="tli-stats-headline-value" data-tli-headline="activeUsersAvg">—</span>
                                        </div>
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Nuovi utenti registrati</span>
                                            <span class="tli-stats-headline-value" data-tli-headline="registeredUsers">—</span>
                                        </div>
                                        <div class="tli-stats-headline-total">
                                            <span class="tli-stats-headline-label">Articoli pubblicati</span>
                                            <span class="tli-stats-headline-value" data-tli-headline="articlesPublished">—</span>
                                        </div>
                                    </div>
                                    <div class="tli-stats-headline-range">
                                        <span class="tli-stats-headline-range-tag" data-tli-headline-range></span>
                                    </div>
                                </div>

                                {# === Range selector === #}
                                <div class="tli-stats-range-selector" id="tli-stats-range-selector"
                                     data-ajax-url="{{ path('app_stats_ajax') }}">
                                    <span class="tli-stats-range-label">Periodo:</span>
                                    {% for days in StatsAllowedDays %}
                                        <button type="button"
                                                class="tli-stats-range-pill {{ days == StatsDefaultDays ? 'tli-active' : '' }}"
                                                data-days="{{ days }}">
                                            {{ days }} giorni
                                        </button>
                                    {% endfor %}
                                    <span class="tli-stats-range-spinner">
                                        <i class="fa-solid fa-circle-notch fa-spin"></i>
                                    </span>
                                </div>

                                {# === Pageviews === #}
                                <div class="tli-stats-card" id="tli-stats-card-pageviews">

                                    <h3><i class="fa-solid fa-eye" style="color: #1091ff;"></i> Visualizzazioni di pagina</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta></div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Periodo attuale</span>
                                            <span class="tli-stats-total-value" data-tli-stats-current>—</span>
                                        </div>
                                        <div class="tli-stats-total tli-last-year">
                                            <span class="tli-stats-total-label">Anno scorso</span>
                                            <span class="tli-stats-total-value" data-tli-stats-lastyear>—</span>
                                        </div>
                                        <div class="tli-stats-total" data-tli-stats-delta-wrap>
                                            <span class="tli-stats-total-label">Variazione</span>
                                            <span class="tli-stats-total-value tli-stats-trend" data-tli-stats-delta>—</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-pageviews"></canvas>
                                    </div>
                                </div>

                                {# === Active users === #}
                                <div class="tli-stats-card" id="tli-stats-card-activeusers">

                                    <h3><i class="fa-solid fa-users" style="color: #26a269;"></i> Visitatori univoci</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta></div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Periodo attuale</span>
                                            <span class="tli-stats-total-value" data-tli-stats-current>—</span>
                                        </div>
                                        <div class="tli-stats-total tli-last-year">
                                            <span class="tli-stats-total-label">Anno scorso</span>
                                            <span class="tli-stats-total-value" data-tli-stats-lastyear>—</span>
                                        </div>
                                        <div class="tli-stats-total" data-tli-stats-delta-wrap>
                                            <span class="tli-stats-total-label">Variazione</span>
                                            <span class="tli-stats-total-value tli-stats-trend" data-tli-stats-delta>—</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-activeusers"></canvas>
                                    </div>
                                </div>

                                {# === Top pages === #}
                                {% if CurrentUser and CurrentUser.isEditor %}
                                <div class="tli-stats-card" id="tli-stats-card-toppages">

                                    <h3><i class="fa-solid fa-trophy" style="color: #e5a50a;"></i> Pagine più viste</h3>
                                    <div class="tli-stats-card-meta" data-tli-toppages-meta></div>
                                    <div class="tli-limited-visibility-warning">
                                        <i class="fa-solid fa-lock"></i> Questa sezione è visibile solo ai membri dello staff
                                    </div>

                                    <div class="tli-stats-toppages-grid" data-tli-toppages-grid style="display:none">
                                        {% for col in [0, 1] %}
                                            <table class="tli-stats-toppages-table">
                                                <thead>
                                                    <tr>
                                                        <th class="tli-stats-toppages-rank">#</th>
                                                        <th class="tli-stats-toppages-title">Pagina</th>
                                                        <th class="tli-stats-toppages-views">Visualizzazioni</th>
                                                    </tr>
                                                </thead>
                                                <tbody data-tli-toppages-body="{{ col }}"></tbody>
                                            </table>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}

                                {# === Top tags === #}
                                {% if CurrentUser and CurrentUser.isEditor %}
                                <div class="tli-stats-card" id="tli-stats-card-toptags">

                                    <h3><i class="fa-solid fa-tags" style="color: #e5a50a;"></i> Tag più visti</h3>
                                    <div class="tli-stats-card-meta" data-tli-toptags-meta></div>
                                    <div class="tli-limited-visibility-warning">
                                        <i class="fa-solid fa-lock"></i> Questa sezione è visibile solo ai membri dello staff
                                    </div>

                                    <div class="tli-stats-toppages-grid" data-tli-toptags-grid style="display:none">
                                        {% for col in [0, 1] %}
                                            <table class="tli-stats-toppages-table">
                                                <thead>
                                                    <tr>
                                                        <th class="tli-stats-toppages-rank">#</th>
                                                        <th class="tli-stats-toppages-title">Tag</th>
                                                        <th class="tli-stats-toppages-views">Visualizzazioni</th>
                                                    </tr>
                                                </thead>
                                                <tbody data-tli-toptags-body="{{ col }}"></tbody>
                                            </table>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}

                                {# === Articles published === #}
                                <div class="tli-stats-card" id="tli-stats-card-articlespublished">

                                    <h3><i class="fa-solid fa-book-open" style="color: #7068b1;"></i> Articoli pubblicati</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta></div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Periodo attuale</span>
                                            <span class="tli-stats-total-value" data-tli-stats-current>—</span>
                                        </div>
                                        <div class="tli-stats-total tli-last-year">
                                            <span class="tli-stats-total-label">Anno scorso</span>
                                            <span class="tli-stats-total-value" data-tli-stats-lastyear>—</span>
                                        </div>
                                        <div class="tli-stats-total" data-tli-stats-delta-wrap>
                                            <span class="tli-stats-total-label">Variazione</span>
                                            <span class="tli-stats-total-value tli-stats-trend" data-tli-stats-delta>—</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-articlespublished"></canvas>
                                    </div>
                                </div>

                                {# === Forum activity === #}
                                <div class="tli-stats-card" id="tli-stats-card-forum">

                                    <h3><i class="fa-solid fa-comments" style="color: #9141ac;"></i> Nuovi post pubblicati sul forum</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta></div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Periodo attuale</span>
                                            <span class="tli-stats-total-value" data-tli-stats-current>—</span>
                                        </div>
                                        <div class="tli-stats-total tli-last-year">
                                            <span class="tli-stats-total-label">Anno scorso</span>
                                            <span class="tli-stats-total-value" data-tli-stats-lastyear>—</span>
                                        </div>
                                        <div class="tli-stats-total" data-tli-stats-delta-wrap>
                                            <span class="tli-stats-total-label">Variazione</span>
                                            <span class="tli-stats-total-value tli-stats-trend" data-tli-stats-delta>—</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-forumposts"></canvas>
                                    </div>

                                    <h4 style="font-size: 16px; color: #515a60; margin: 26px 0 8px;">
                                        <i class="fa-solid fa-trophy" style="color: #e5a50a;"></i>
                                        Utenti più attivi
                                    </h4>

                                    <div class="tli-stats-toppages-grid" data-tli-topposters-grid style="display:none">
                                        {% for col in [0, 1] %}
                                            <table class="tli-stats-toppages-table">
                                                <thead>
                                                    <tr>
                                                        <th class="tli-stats-toppages-rank">#</th>
                                                        <th class="tli-stats-toppages-title">Utente</th>
                                                        <th class="tli-stats-toppages-views">Post</th>
                                                    </tr>
                                                </thead>
                                                <tbody data-tli-topposters-body="{{ col }}"></tbody>
                                            </table>
                                        {% endfor %}
                                    </div>
                                </div>

                                {# === Registered users === #}
                                <div class="tli-stats-card" id="tli-stats-card-registeredusers">

                                    <h3><i class="fa-solid fa-user-check" style="color: #1c9099;"></i> Numero totale di utenti registrati e attivati</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta></div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Totale al termine del periodo</span>
                                            <span class="tli-stats-total-value" data-tli-stats-current>—</span>
                                        </div>
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Nuovi nel periodo</span>
                                            <span class="tli-stats-total-value" data-tli-stats-new-in-period>—</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-registeredusers"></canvas>
                                    </div>

                                    <div class="tli-stats-legend-hint">

                                    </div>
                                </div>

                                {# === Newsletter subscribers === #}
                                <div class="tli-stats-card" id="tli-stats-card-newsletter">

                                    <h3><i class="fa-solid fa-envelope-open-text" style="color: #e66100;"></i> Iscritti newsletter</h3>
                                    <div class="tli-stats-card-meta" data-tli-stats-meta></div>

                                    <div class="tli-stats-totals">
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Totale al termine del periodo</span>
                                            <span class="tli-stats-total-value" data-tli-stats-current>—</span>
                                        </div>
                                        <div class="tli-stats-total">
                                            <span class="tli-stats-total-label">Nuovi nel periodo</span>
                                            <span class="tli-stats-total-value" data-tli-stats-new-in-period>—</span>
                                        </div>
                                    </div>

                                    <div class="tli-stats-canvas-wrap">
                                        <canvas id="tli-chart-newsletter"></canvas>
                                    </div>

                                    <div class="tli-stats-legend-hint">
                                        Iscritti alla newsletter al termine di ogni giorno. <strong>Approssimato:</strong> phpBB
                                        non traccia opt-in/opt-out storici, gli utenti sono attribuiti alla data di
                                        registrazione in base all'opzione attualmente attiva.
                                    </div>
                                </div>

                                {# === Top referrers === #}
                                {% if CurrentUser and CurrentUser.isEditor %}
                                    <div class="tli-stats-card" id="tli-stats-card-topreferrers">

                                        <h3><i class="fa-solid fa-arrow-right-to-bracket" style="color: #9141ac;"></i> Top referrer</h3>
                                        <div class="tli-stats-card-meta" data-tli-topreferrers-meta></div>
                                        <div class="tli-limited-visibility-warning">
                                            <i class="fa-solid fa-lock"></i> Questa sezione è visibile solo ai membri dello staff
                                        </div>

                                        <div class="tli-stats-toppages-grid" data-tli-topreferrers-grid style="display:none">
                                            {% for col in [0, 1] %}
                                                <table class="tli-stats-toppages-table">
                                                    <thead>
                                                        <tr>
                                                            <th class="tli-stats-toppages-rank">#</th>
                                                            <th class="tli-stats-toppages-title">Referrer</th>
                                                            <th class="tli-stats-toppages-views">Visualizzazioni</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody data-tli-topreferrers-body="{{ col }}"></tbody>
                                                </table>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endif %}

                            {% endif %}

                        </div>
                    </div>

                </article>

            </div>
        </div>
    </section>

{% endblock %}

{% block javascripts %}

    {{ parent() }}

    {% if StatsConfigured %}
        {{ encore_entry_script_tags('stats') }}
    {% endif %}

{% endblock %}
