<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{% block metaTitle %}{{ metaTitle ?? null }}{% endblock %}{% block metaTitleSuffix %}{{ metaTitleSuffix ?? null }}{% endblock %}</title>
    <meta property="og:title" content="{{ block('metaTitle') }}">
    <meta name="twitter:title" content="{{ block('metaTitle') }}">

    <meta name="description" content="{% block metaDescription %}{{ metaDescription ?? null }}{% endblock %}">
    <meta property="og:description" content="{{ block('metaDescription') }}">
    <meta name="twitter:description" content="{{ block('metaDescription') }}">

    <link rel="canonical" href="{% block metaCanonicalUrl %}{{ metaCanonicalUrl ?? app.request.uri }}{% endblock %}">
    <meta property="og:url" content="{{ block('metaCanonicalUrl') }}">

    <meta property="og:type" content="{% block metaOgType %}website{% endblock %}">
    <meta name="twitter:card" content="summary_large_image">
    <meta property="og:image" content="{% block metaPageImageUrl %}{{ metaPageImageUrl ?? null }}{% endblock %}">
    <meta name="twitter:image" content="{{ block('metaPageImageUrl') }}">

    <meta name="twitter:site" content="{% block metaTwitterHandle %}{{ websiteTwitterHandle ?? null }}{% endblock %}">
    <meta name="twitter:creator" content="{% block metaTwitterHandleAuthor %}{{ authorTwitterHandle ?? websiteTwitterHandle ?? null }}{% endblock %}">

    <meta name="robots" content="{%- block metaRobots -%}{{ metaRobots ?? 'index,follow' }}{%- endblock -%}">

    <link rel="icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="search" type="application/opensearchdescription+xml" title="TurboLab.it" href="/open-search.xml">
    <link rel="manifest" crossorigin="use-credentials" href="/manifest.json">

    <link rel="alternate" type="application/rss+xml" title="Feed" href="{% block metaFeedUrl %}{{ absolute_url(path('app_feed')) }}{% endblock %}">

    {% if (Pages.prev.url ?? null) is not empty %}
        <link rel="prev" href="{{ Pages.prev.url }}">
    {% endif %}

    {% if (Pages.next.url ?? null) is not empty %}
        <link rel="next" href="{{ Pages.next.url }}">
    {% endif %}

    {% include 'ads/clickio/header.html.twig' %}

    <!-- Google Analytics (GA4) Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BMZ19KGXP8"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-BMZ19KGXP8', {'anonymize_ip': true});
    </script>

    {% block stylesheets %}

        {# Font Awesome solid webfont: preload so icons render at (or right after) first paint #}
        <link rel="preload" href="{{ asset('build/fonts/fa-solid-900.woff2') }}" as="font" type="font/woff2" crossorigin>


        {# Bootstrap is bundled (yarn) into app.css/app.js #}
        {{ inline_css('build/app.css') }}

    {% endblock %}

</head>

<body class="home-1-bg" data-tli-visit-url="{{ path('app_ajax_count-visit') }}"
      data-tli-cms-type="{{ cmsType ?? null }}" data-tli-cms-id="{{ cmsId ?? null }}">

    <div id="tli-userbar-load-target" data-loading-url="{{ path('app_ajax_userbar') }}">
        <div class="container" style="padding: 10px">
            <div class="col-12">
                <i class="fa-solid fa-spinner fa-spin-pulse" style="color: #000000;"></i>
                Sei già dei nostri? Login in corso...
            </div>
        </div>
    </div>

    <header class="header-area">

        <div class="header-centerbar">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-4">
                        <div class="logo">
                            <a href="{{ path('app_home') }}">
                                <img src="{{ asset('images/logo/turbolab.it.png') }}"
                                     width="360" height="62" alt="Il logo di TurboLab.it">
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="header-menubar">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-12">
                        <div class="header-menu">
                            <div class="stellarnav">
                                <ul>
                                    <li>
                                        <a class="{{ activeMenu == 'home' ? 'active' : '' }}" href="{{ path('app_home') }}">
                                            <i class="fa-solid fa-house"></i> Home
                                        </a>
                                    </li>
                                    <li class="has-sub">
                                        <a href="{{ path('app_home') }}forum">
                                            <i class="fa-solid fa-users"></i> Forum <i class="fa-solid fa-angle-down"></i>
                                        </a>
                                        <ul>
                                            <li><a href="{{ path('app_home') }}forum/search.php?search_id=egosearch">I tuoi messaggi</a></li>
                                            <li><a href="{{ path('app_home') }}forum/search.php?search_id=unreadposts">Messaggi non letti</a></li>
                                            <li><a href="{{ path('app_home') }}forum/ucp.php?i=pm&amp;folder=inbox">Messaggi privati</a></li>
                                        </ul>
                                    </li>

                                    {% for Link in FrontendHelper.NavTopCategories %}
                                        <li>
                                            <a class="{{ activeMenu == Link.activeMenu ? 'active' : '' }}" href="{{ Link.url }}">
                                                {% for fa in Link.fa %}
                                                    <i class="{{ fa }}"></i>
                                                {% endfor %} &nbsp;{{ Link.name }}
                                            </a>
                                        </li>
                                    {% endfor %}

                                    <li class="has-sub">
                                        <a class="{{ activeMenu == 'guide' ? 'active' : '' }} disabled-link" href="#">
                                            <i class="fa-solid fa-book"></i> Guide <i class="fa-solid fa-angle-down"></i>
                                        </a>
                                        <ul>
                                            {% for Link in FrontendHelper.NavOtherCategories %}
                                                <li>
                                                    <a href="{{ Link.url }}">
                                                        <i class="{{ Link.fa|first }}"></i> &nbsp;{{ Link.name }}
                                                    </a>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    </li>

                                    <li>
                                        <a class="{{
                                            activeMenu == constant('App\\Controller\\SearchController::SECTION_SLUG')
                                                ? 'active disabled-link' : '' }} " href="{{ path('app_search') }}">
                                            <i class="fa-solid fa-magnifying-glass" style="color: #e66100;"></i> Cerca
                                        </a>
                                    </li>

                                    <li>
                                        <a href="#contact" class="prevent-change-url">
                                            <i class="fa-solid fa-envelope" style="color: #e01b24;"></i> Contatti
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </header>

    {% include 'ads/clickio/sticky-leaderboard.html.twig' %}

    <main>
        {% block bodyMainContent %}{% endblock %}

        {% include '@TurboLabItPaginator/pagination-bootstrap.html.twig' %}
    </main>

    {% include 'user/login-modal.html.twig' %}

    <footer class="footer-area">
        <div class="container">
            <div class="footer-topbar">
                <div class="row align-items-center">
                    <div class="col-lg-7 col-md-5">
                        <div class="footer-logo">
                            <a href="{{ path('app_file', {fileId: 18}) }}" target="_blank">
                                <img src="{{ asset('images/logo/turbolab.it.png') }}"
                                     width="360" height="62" alt="Il logo di TurboLab.it">
                            </a>
                            <ul>
                                {% for Link in FrontendHelper.FollowUsLinks %}
                                    <li>
                                        <a href="{{ Link.url }}" {% if Link.blank %}target="_blank"{% endif %} title="{{ Link.name }}">
                                            {% for fa in Link.fa %}
                                                <i class="{{ fa }} fa-xl"></i>
                                            {% endfor %}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <div class="site-description">
                TurboLab.it è un sito indipendente e no-profit, totalmente gestito da appassionati di informatica (come te!).
                Sin dal 2013, pubblichiamo gratuitamente <strong>guide per PC e smartphone con sistemi operativi Windows, Linux e Android</strong>.
                Abbiamo oltre 20 anni di esperienza professionale nel <strong>supporto tecnico (helpdesk) e nella gestione di
                    server web</strong> e tecnologie annesse, che condividiamo tramite guide passo per passo.
                Trattiamo anche <strong>Bitcoin, Ethereum e altre criptovalute basate su blockchain</strong>, focalizzandoci
                principalmente sugli aspetti tecnologici e le applicazioni pratiche.
                <strong>Il nostro forum è il punto di incontro italiano per gli appassionati di computer e informatica</strong>, e consente
                di confrontarsi con altri esperti, appassionati e professionisti IT, nonché di richiedere un aiuto con i
                propri problemi tecnologici. Per partecipare è sufficiente una registrazione gratuita.
            </div>
            <div class="footer-widget-area">
                <div class="row">
                    <div class="col-lg-8">
                        <div class="footer-widget-right-border">
                            <div class="row">
                                <div class="col-lg-8 col-md-8">
                                    <div class="widget widget-list">
                                        <div class="section-title section-title-2">
                                            <h3 class="title">Altre pagine</h3>
                                        </div>
                                        <div class="list d-flex justify-content-between">
                                            <ul>
                                                <li>
                                                    <a href="{{ path('app_article_shorturl', {id: constant('App\\Service\\Cms\\Article::ID_DONATIONS')}) }}">
                                                        <i class="fa-solid fa-heart-circle-plus fa-beat" style="color: #ed333b;"></i> Donazioni
                                                    </a>
                                                </li>


                                                <li>
                                                    <a href="{{ FrontendHelper.registerUrl }}">
                                                        <i class="fa-solid fa-users"></i> Registrazione (gratuita)
                                                    </a>
                                                </li>

                                                <li>
                                                    <a href="{{ path('app_newsletter_preview') }}">
                                                        <i class="fa-solid fa-envelope-open-text"></i> Anteprima newsletter
                                                    </a>
                                                </li>

                                                <li>
                                                    <a href="{{ path('app_calendar') }}">
                                                        <i class="fa-solid fa-calendar-days"></i> Calendario pubblicazioni
                                                    </a>
                                                </li>

                                                <li>
                                                    <a href="{{ path('app_info') }}">
                                                        <i class="fa-solid fa-server"></i> Info tecniche server
                                                    </a>
                                                </li>

                                                <li>
                                                    <a href="{{ path('app_stats') }}">
                                                        <i class="fa-solid fa-chart-simple"></i> Statistiche
                                                    </a>
                                                </li>

                                                <li>
                                                    <a href="https://github.com/TurboLabIt/TurboLab.it" target="_blank">
                                                        <i class="fa-brands fa-github"></i> Codice sorgente (GitHub)
                                                    </a>
                                                </li>
                                            </ul>

                                            <ul>
                                                {% for View in FrontendHelper.Views.All %}
                                                    <li>
                                                        <a href="{{ View.url }}">{{ View.title }}</a>
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-4">
                                    <div class="widget widget-list widget-list-2" id="contact">
                                        <div class="section-title section-title-2">
                                            <h3 class="title">Contact</h3>
                                        </div>
                                        <div class="glowing-image-container">
                                            <img src="{{ asset('build/images/clock.png') }}" class="glowing-image"
                                                 alt="Contatto" loading="lazy">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="footer-twitter-post">
                                <div class="row">
                                    <div class="col-lg-5 col-md-5">
                                        <div class="widget widget-list">
                                            <div class="section-title section-title-2">
                                                <h3 class="title">Privacy</h3>
                                            </div>
                                            <div class="list">
                                                <ul>
                                                    <li><a href="{{ path('app_article_shorturl', {id: constant('App\\Service\\Cms\\Article::ID_PRIVACY_POLICY')}) }}">Informativa privacy</a></li>
                                                    <li><a href="{{ path('app_article_shorturl', {id: constant('App\\Service\\Cms\\Article::ID_COOKIE_POLICY')}) }}">Informativa cookie</a></li>
                                                    <li><a href="#" onclick="if(window.__lxG__consent__!==undefined&&window.__lxG__consent__.getState()!==null){window.__lxG__consent__.showConsent()} else {alert('This function only for users from European Economic Area (EEA)')}; return false">Change privacy settings</a></li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-7 col-md-7">
                                        <div class="widget widget-list partner-container">
                                            <div class="section-title section-title-2">
                                                <h3 class="title">Partner</h3>
                                            </div>
                                            <div class="list d-flex justify-content-between">
                                                <ul>
                                                    <li><a href="https://amzn.to/3XI6I24" target="_blank">Amazon.it</a></li>
                                                    <li><a href="https://www.telegramitalia.it" target="_blank">Telegram Italia</a></li>
                                                </ul>
                                                <ul>
                                                    <li><a href="https://pasticciotti.it" target="_blank">Pasticciotti</a></li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="footer-rightbar mt-60">
                            <div class="row">
                                <div class="col-lg-12 col-md-6">
                                    <div class="widget widget-news">
                                        <div class="section-title section-title-2">
                                            <h3 class="title">Vuoi partecipare a TurboLab.it?</h3>
                                        </div>
                                        <div class="footer-news">
                                            {% for Article in FrontendHelper.guidesForAuthors %}
                                                <div class="gallery_item gallery_item-style-2 footer_gallery_item">
                                                    <div class="gallery_item_content">
                                                        <h4 class="title">
                                                            <a href="{{ Article.url }}">{{ Article.title }}</a>
                                                        </h4>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <div class="footer-copyright">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="copyright-item d-block d-md-flex justify-content-between align-items-center">
                        <p>
                            <a property="dct:title" rel="cc:attributionURL"
                                href="{{ metaCanonicalUrl ?? app.request.uri }}">{% block licenseWorkName %}TurboLab.it{% endblock %}</a>
                            {% block licenseWorkAuthor %}{% endblock %}
                            is licensed under
                            <a href="https://creativecommons.org/licenses/by-nd/4.0/?ref=chooser-v1" target="_blank"
                               rel="license noopener noreferrer" class="tli-cc-copyright">CC BY-ND 4.0</a>
                            <a href="https://creativecommons.org/licenses/by-nd/4.0/?ref=chooser-v1" target="_blank"
                               rel="license noopener noreferrer" class="tli-cc-copyright-icon">
                                <img width="22" height="22" src="https://mirrors.creativecommons.org/presskit/icons/cc.svg?ref=chooser-v1" alt="cc">
                                <img width="22" height="22" src="https://mirrors.creativecommons.org/presskit/icons/by.svg?ref=chooser-v1" alt="by">
                                <img width="22" height="22" src="https://mirrors.creativecommons.org/presskit/icons/nd.svg?ref=chooser-v1" alt="nd">
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% block javascripts_base %}

        <script src="https://code.jquery.com/jquery-4.0.0.min.js"></script>
        <script src="https://code.jquery.com/jquery-migrate-4.0.1.min.js"></script>

    {% endblock %}

    {% block javascripts %}

        <script src="/assets/js/stellarnav.min.js"></script>
        <script src="/assets/js/main.js"></script>
        {{ encore_entry_script_tags('app') }}

        <script src="https://platform-api.sharethis.com/js/sharethis.js#property=59e0553a0ec52b001145b377&product=unknown" async></script>

    {% endblock %}

</body>

</html>
