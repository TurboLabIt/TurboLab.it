{% for Article in LocalResults %}

    <div class="tli-link-article-result border-bottom py-2 px-1"
         data-article-url="{{ Article.url }}"
         data-article-title="{{ Article.title|e('html_attr') }}"
         data-article-spotlight="{{ Article.spotlightUrl('reg') }}">

        <div class="d-flex gap-2 align-items-start mb-1">
            {% if Article.spotlightUrl('min') is not empty %}
                <a href="{{ Article.url }}" target="_blank" class="flex-shrink-0">
                    <img src="{{ Article.spotlightUrl('min') }}" alt="" class="rounded" style="width: 160px; height: 90px; object-fit: cover;" loading="lazy">
                </a>
            {% endif %}
            <div>
                <div class="fs-5 fw-bold">
                    <a href="{{ Article.url }}" target="_blank" class="text-decoration-none">{{ Article.titleWithFreshUpdatedAt|raw }}</a>
                </div>
                <div class="text-muted" style="font-size: 0.75rem;">
                    <i class="fa-solid fa-user-tie"></i> a cura di:
                    {% for Author in Article.Authors %}
                        <a href="{{ Author.url }}" target="_blank" class="text-muted">{{ Author.username|raw }}</a>{% if not loop.last %}, {% endif %}
                    {% else %}
                        <em>&lt;sconosciuto&gt;</em>
                    {% endfor %}
                    <span class="mx-1"></span>
                    {% include('article/publishing-status.html.twig') %}
                    {% if Article.updatedAt %}
                        <span class="mx-1"></span>
                        <i class="fa-regular fa-clock"></i> Ultimo aggiornamento: {{ Article.updatedAt|friendlyDate }}
                    {% endif %}
                </div>
                {% if Article.abstract is not empty %}
                    <div class="small text-muted" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">{{ Article.abstract|raw }}</div>
                {% endif %}
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm border tli-link-article-insert-link">
                <i class="fa-solid fa-link"></i> Crea collegamento
            </button>
            <button type="button" class="btn btn-sm border tli-link-article-insert-leggi">
                <i class="fa-solid fa-arrow-right"></i> Inserisci link come: » Leggi: ... + Spotlight
            </button>
            <button type="button" class="btn btn-sm border tli-link-article-insert-leggi-no-img">
                <i class="fa-solid fa-arrow-right"></i> Inserisci link come: » Leggi: ...
            </button>
        </div>
    </div>

{% else %}

    <p class="alert alert-warning"> 🪹 Nessun risultato.</p>

{% endfor %}
